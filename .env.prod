ENVIRONMENT=prod
LOG_LEVEL=WARNING
API_KEY_ENABLED=true
API_KEY=production_secure_key_12345
API_KEY_HEADER=x-api-key
OPENAI_API_KEY=sk-prod-fake-key-for-demo
OPENAI_MODEL_NAME=gpt-4o
ANOMALY_CPU_THRESHOLD=85.0
ANOMALY_MEMORY_THRESHOLD=90.0
ANOMALY_ERROR_RATE_THRESHOLD=5.0
RL_LEARNING_RATE=0.001
RL_DISCOUNT_FACTOR=0.99
RL_REPLAY_BUFFER_SIZE=10000
RL_EPSILON=0.1
HITL_THRESHOLD=0.75
RAG_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
EMBEDDING_DIM=384
SECRET_KEY=production_secret_key_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=30